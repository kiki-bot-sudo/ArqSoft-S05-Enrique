@using CitasApp.Domain.Models
@model IEnumerable<Paciente>

@{
    ViewData["Title"] = "Lista de Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Pacientes Registrados</h1>
        <span class="badge bg-primary fs-5">En Memoria (JSON)</span>
    </div>

    <table class="table table-striped table-hover border shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Correo Electrónico</th>
                <th>Teléfono</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var paciente in Model)
            {
                <tr>
                    <td>@paciente.Id</td>
                    <td class="font-weight-bold">@paciente.Nombre</td>
                    <td>@paciente.Email</td>
                    <td>@paciente.Telefono</td>
                    <td class="text-center">
                        <a asp-controller="Paciente" asp-action="Detalle" asp-route-id="@paciente.Id" class="btn btn-info btn-sm text-white">
                            <i class="bi bi-eye"></i> Ver Detalle
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>