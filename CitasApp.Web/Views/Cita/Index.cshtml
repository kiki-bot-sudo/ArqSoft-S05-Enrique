@using CitasApp.Domain.Models
@model IEnumerable<Cita>

@{
    ViewData["Title"] = "Agenda de Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Agenda de Citas Médicas</h1>
        <span class="badge bg-info text-dark fs-5">Control Global</span>
    </div>

    <table class="table table-striped table-hover border shadow-sm">
        <thead class="table-info table-dark">
            <tr>
                <th>ID Cita</th>
                <th>ID Paciente</th>
                <th>ID Médico</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Motivo de Consulta</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cita in Model)
            {
                <tr>
                    <td>@cita.Id</td>
                    <td>Paciente #@cita.PacienteId</td>
                    <td>Médico #@cita.MedicoId</td>
                    <td>@cita.Fecha</td>
                    <td>@cita.Hora</td>
                    <td>@cita.Motivo</td>
                    <td>
                        @if (cita.Estado == "Confirmada")
                        {
                            <span class="badge bg-success">@cita.Estado</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@cita.Estado</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>